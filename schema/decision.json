{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gmem.dev/schema/decision.json",
  "title": "Decision",
  "description": "An architectural choice with rationale.",
  "type": "object",
  "required": ["title", "decision", "rationale", "date"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Generated server-side if omitted on write"
    },
    "title": { "type": "string", "minLength": 1 },
    "decision": { "type": "string", "minLength": 1, "description": "One-sentence summary of the choice" },
    "alternatives": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rationale": { "type": "string", "minLength": 1 },
    "date": { "type": "string", "format": "date-time" },
    "relatedTo": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "id"],
        "additionalProperties": false,
        "properties": {
          "kind": { "type": "string", "enum": ["Program", "Account", "Instruction", "Decision", "Finding", "Integration"] },
          "id":   { "type": "string" }
        }
      }
    }
  }
}
